#!/usr/bin/env python3

import argparse
import os
import subprocess
import sys
import tempfile
import time
import shutil

# Configuration
DEFAULT_IMAGE = "https://cloud.debian.org/images/cloud/bookworm/latest/debian-12-genericcloud-arm64.qcow2"
SKELETON_DIR = os.path.expanduser("~/.gemvm/skeleton")

def run_cmd(cmd, check=True, capture_output=False):
    """Utility to run shell commands."""
    try:
        return subprocess.run(cmd, shell=True, check=check, capture_output=capture_output, text=True)
    except subprocess.CalledProcessError as e:
        print(f"Error running command: {cmd}")
        if e.stderr:
            print(e.stderr)
        sys.exit(1)

def get_lima_config_yaml(project_name):
    """Generates the Lima configuration YAML as a string."""
    # Use a template and replace to avoid f-string escape sequence issues
    template = """
vmType: "vz"
arch: "aarch64"
images:
- location: "{DEFAULT_IMAGE}"
  arch: "aarch64"
cpus: 4
memory: "4GiB"
containerd:
  system: false
  user: false
provision:
- mode: system
  script: |
    #!/bin/bash
    set -e
    apt-get update
    apt-get install -y sudo ca-certificates git build-essential curl tmux screen python3 python3-pip
    
    # Install Node.js v20 from NodeSource (Gemini CLI requires Node v20+)
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
    apt-get install -y nodejs
    
    # Ensure default user has passwordless sudo
    echo "$(whoami) ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/99-gemvm
    # Ensure global npm bin directory is in PATH for all users
    NPM_CONFIG_PREFIX=$(npm config get prefix)
    echo "export PATH=\\$PATH:$NPM_CONFIG_PREFIX/bin" > /etc/profile.d/gemvm-path.sh
- mode: user
  script: |
    #!/bin/bash
    set -e
    # Install Gemini CLI globally
    sudo npm install -g @google/gemini-cli
    # Setup initial Gemini config directory
    mkdir -p ~/.gemini
    # Trust all folders for Gemini CLI to enable "yolo" flow without prompts
    echo '{"/": "TRUST_FOLDER"}' > ~/.gemini/trustedFolders.json
    
    # Create a basic .bashrc if it doesn't exist
    if [ ! -f ~/.bashrc ]; then
      cat << 'EOF' > ~/.bashrc
    # Basic .bashrc for gemvm
    export PS1='\\[\\e[1;32m\\]gemvm\\[\\e[0m\\]:\\[\\e[1;34m\\]\\w\\[\\e[0m\\]\\$ '
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
    [ -f /etc/bash_completion ] && . /etc/bash_completion
    EOF
    fi
"""
    return template.replace("{DEFAULT_IMAGE}", DEFAULT_IMAGE)

def create_vm(args):
    project_name = args.project
    print(f"[*] Ensuring VM {project_name} is ready...")

    # Check if VM already exists
    check_exists = subprocess.run(f"limactl list {project_name}", shell=True, capture_output=True, text=True)
    exists = project_name in check_exists.stdout

    if not exists:
        print(f"[*] Creating new VM for project: {project_name}...")
        yaml_content = get_lima_config_yaml(project_name)
        with tempfile.NamedTemporaryFile(mode='w', suffix='.yaml', delete=False) as f:
            f.write(yaml_content)
            temp_config_path = f.name

        try:
            # Start/Create the VM
            print("[*] Starting VM via limactl (this may take a few minutes)...")
            run_cmd(f"limactl start --name={project_name} {temp_config_path} --tty=false")
        finally:
            if os.path.exists(temp_config_path):
                os.remove(temp_config_path)
    else:
        # VM exists, just make sure it's running
        print(f"[*] VM {project_name} already exists. Ensuring it is started...")
        run_cmd(f"limactl start {project_name} --tty=false")

    # Sync credentials
    sync_creds(project_name)
    
    # Sync skeleton
    sync_skeleton(project_name, args.skeleton)
    
    print(f"[*] VM {project_name} is ready.")
    
    # Start interactive session
    start_session(project_name)

def sync_creds(project_name):
    print("[*] Synchronizing Gemini credentials...")
    host_gemini_dir = os.path.expanduser("~/.gemini")
    # Using .gemini (relative to home) to avoid host-side ~ expansion issues
    files_to_copy = ["oauth_creds.json", "google_accounts.json", "settings.json", "installation_id"]
    
    run_cmd(f"limactl shell {project_name} mkdir -p .gemini")
    
    for f in files_to_copy:
        src = os.path.join(host_gemini_dir, f)
        if os.path.exists(src):
            # Target path is relative to the guest's home directory
            run_cmd(f"limactl copy {src} {project_name}:.gemini/{f}")

def sync_skeleton(project_name, skeleton_path):
    path = skeleton_path or SKELETON_DIR
    if os.path.exists(path) and os.listdir(path):
        print(f"[*] Copying skeleton from {path}...")
        # Ensure all parts of the command use f-strings for project_name expansion
        # Use bash -c in the guest so that ~ expands properly without quoting issues
        tar_cmd = (
            f"tar -C {path} --no-xattrs --no-mac-metadata "
            f"--exclude='.DS_Store' --exclude='.localized' "
            f"-cf - . | limactl shell {project_name} bash -c 'tar -C ~ -xf -'"
        )
        run_cmd(tar_cmd)
    else:
        if skeleton_path:
            print(f"[!] Warning: Skeleton path {path} does not exist or is empty.")
        else:
            # Silent skip for the default path if it doesn't exist
            pass

def start_session(project_name):
    print(f"[*] Attaching to VM {project_name}...")
    # Exec into the VM and start a tmux session with gemini CLI
    os.execvp("limactl", ["limactl", "shell", project_name, "tmux", "new-session", "-A", "-s", "gemini", "gemini --yolo"])

def ssh_vm(args):
    print(f"[*] Connecting to VM {args.project}...")
    ssh_config = os.path.expanduser(f"~/.lima/{args.project}/ssh.config")
    if not os.path.exists(ssh_config):
        print(f"[!] Error: SSH configuration for {args.project} not found. Is the VM created?")
        sys.exit(1)
    
    # Use direct ssh with the lima config.
    # We pass -o ControlPath=none to bypass Lima's connection multiplexing.
    # Multiplexed connections created in the background don't forward the agent,
    # so reusing them breaks the -A flag.
    cmd = ["ssh", "-F", ssh_config, "-o", "ControlPath=none", f"lima-{args.project}"] + args.ssh_args
    os.execvp("ssh", cmd)

def stop_vm(args):
    print(f"[*] Stopping VM {args.project}...")
    run_cmd(f"limactl stop {args.project}")

def delete_vm(args):
    print(f"[*] Deleting VM {args.project}...")
    run_cmd(f"limactl delete {args.project} --force")

def cp_vm(args):
    print(f"[*] Copying files...")
    # limactl copy works similar to scp. Example: limactl copy my-project:file.txt .
    # We pass the arguments directly.
    run_cmd(f"limactl copy {' '.join(args.cp_args)}")

def list_vms(args):
    run_cmd("limactl list")

def main():
    parser = argparse.ArgumentParser(description="gemvm: Manage isolated Gemini CLI development VMs")
    subparsers = parser.add_subparsers(dest="command", help="Commands")

    # Create
    create_parser = subparsers.add_parser("create", help="Create a new project VM")
    create_parser.add_argument("project", help="Project name")
    create_parser.add_argument("--skeleton", help="Path to skeleton directory")
    create_parser.set_defaults(func=create_vm)

    # SSH
    ssh_parser = subparsers.add_parser("ssh", help="SSH into the project VM")
    ssh_parser.add_argument("project", help="Project name")
    ssh_parser.add_argument("ssh_args", nargs=argparse.REMAINDER, help="Additional SSH arguments")
    ssh_parser.set_defaults(func=ssh_vm)

    # Copy
    cp_parser = subparsers.add_parser("cp", help="Copy files to/from the VM")
    cp_parser.add_argument("cp_args", nargs=argparse.REMAINDER, help="Arguments for copy (e.g., project:file.txt .)")
    cp_parser.set_defaults(func=cp_vm)

    # Stop
    stop_parser = subparsers.add_parser("stop", help="Stop the project VM")
    stop_parser.add_argument("project", help="Project name")
    stop_parser.set_defaults(func=stop_vm)

    # Delete
    delete_parser = subparsers.add_parser("delete", help="Delete the project VM")
    delete_parser.add_argument("project", help="Project name")
    delete_parser.set_defaults(func=delete_vm)

    # List
    list_parser = subparsers.add_parser("list", help="List all VMs")
    list_parser.set_defaults(func=list_vms)

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    args.func(args)

if __name__ == "__main__":
    main()
